# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# API Configuration (Python backend — only used if you run the FastAPI server too)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Optional: Base path (leave empty for root)
NEXT_PUBLIC_BASE_PATH=

# Auth debugging (verbose NextAuth logs)
AUTH_DEBUG=true

# ─── Supervity AI Workflow API ────────────────────────────────────────────────
# IMPORTANT: These are SERVER-SIDE ONLY secrets.
# Do NOT prefix with NEXT_PUBLIC_ — the bearer token must never reach the browser.

SUPERVITY_API_URL=https://auto-workflow-api.supervity.ai/api/v1/workflow-runs/execute/stream

