# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# API Configuration (Python backend — only used if you run the FastAPI server too)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Optional: Base path (leave empty for root)
NEXT_PUBLIC_BASE_PATH=

# Auth debugging (verbose NextAuth logs)
AUTH_DEBUG=true

# ─── Supervity AI Workflow API ────────────────────────────────────────────────
# IMPORTANT: These are SERVER-SIDE ONLY secrets.
# Do NOT prefix with NEXT_PUBLIC_ — the bearer token must never reach the browser.

SUPERVITY_API_URL=https://auto-workflow-api.supervity.ai/api/v1/workflow-runs/execute/stream

# Keycloak Bearer Token (copy from Supervity dashboard — expires periodically)
SUPERVITY_BEARER_TOKEN=your-supervity-bearer-token-here

# ─── Supervity Workflow IDs per NEXUS OS Node ─────────────────────────────────
# These are optional — defaults are baked into /src/lib/supervity.ts
# Override here if your workflow IDs change without a code deploy.

SUPERVITY_WORKFLOW_ATLAS=019e1ea6-819f-7000-98ef-fbeeb581f54a
SUPERVITY_WORKFLOW_QUILL=019e324a-a7ec-7000-9085-52e08630dbfe
SUPERVITY_WORKFLOW_ORACLE=019e2faf-64ac-7000-9dc7-1da580f0482d
SUPERVITY_WORKFLOW_VANGUARD=019e2c17-4b27-7000-97a5-835d1fb19716
SUPERVITY_WORKFLOW_HERALD=019e1ede-0545-7000-b66a-ded437146b1b
SUPERVITY_WORKFLOW_LEDGER=019e1ebd-38d5-7000-9223-828915556edb
SUPERVITY_WORKFLOW_HELIOS=019e1eb6-5e05-7000-a235-56f5c9bd5a80
SUPERVITY_WORKFLOW_SENTRY=019e1eb0-6554-7000-a018-8203d9a61f95
SUPERVITY_WORKFLOW_LENS=019e1eac-76ba-7000-a969-35ff30e57f89