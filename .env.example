# ===================================================================
#      AUTOPILOT COMMAND CENTER - ENVIRONMENT CONFIGURATION
# -------------------------------------------------------------------
#  Copy this file to .env to get started.
#  Defaults work out of the box — just run: make up
# ===================================================================

# ------------------------------------------------------------
# BACKEND
# ------------------------------------------------------------
APP_ENV=development
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=INFO

# Auth bypass — all requests auto-authenticated as Dev User (admin role)
AUTH_BYPASS=true

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_BASE_PATH=

# NextAuth (required for session management even with AUTH_BYPASS)
NEXTAUTH_URL=http://localhost:3001

# REQUIRED: A secret used to sign and encrypt NextAuth.js tokens.
# Generate with:
#   macOS/Linux: openssl rand -base64 32
#   Windows:     [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
NEXTAUTH_SECRET=

# ------------------------------------------------------------
# DOCKER
# ------------------------------------------------------------
# "dev" = hot reload | "prod" = optimized build
FRONTEND_TARGET=dev

# ------------------------------------------------------------
# SUPERVITY AI AGENT API
# ------------------------------------------------------------
# Base URL per Supervity API Reference: https://auto.supervity.ai
SUPERVITY_BASE_URL=https://auto.supervity.ai

# Bearer token — your Supervity access token (Settings → API Keys)
SUPERVITY_API_KEY=your_supervity_token_here

# The Workflow ID for your Atlas Orchestrator agent
# Find it on: auto.supervity.ai → Workflows → Atlas → copy ID from URL
ATLAS_WORKFLOW_ID=your_atlas_workflow_id_here

NEXT_PUBLIC_APP_NAME="GrowthPilot OS"
